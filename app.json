{
  "expo": {
    "name": "RESQID",
    "slug": "safety-qr-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "safetyqrapp",
    "icon": "./assets/images/app_icon.png",
    "userInterfaceStyle": "automatic",
    "updates": {
      "enabled": false
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.animesh144.safetyqrapp",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan student QR cards.",
        "NSFaceIDUsageDescription": "Face ID is used to secure your child's emergency data."
      }
    },
    "android": {
      "package": "com.animesh144.safetyqrapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app_icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app_icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#1a1a1a"
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow RESQID to access your camera to scan QR cards."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow RESQID to use Face ID to secure your account."
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "8b193d0d-4f69-41d2-8e0e-59aeecc83565"
      }
    },
    "owner": "optimas144"
  }
}
